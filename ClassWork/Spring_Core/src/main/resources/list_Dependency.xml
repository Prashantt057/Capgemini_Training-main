<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
    http://www.springframework.org/schema/beans
    http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id = "P1" class = "dependency_injection.Person">
        <property name="pId" value="2220"/>
        <property name="pName" value="Prashant"/>
        <property name="aadhar" ref="a1"/>
    </bean>
    <bean id = "a1" class = "dependency_injection.Aadhar">
        <property name="aadharId" value="2221"/>
        <property name="aadharName" value="Prashant Singh"/>
        <property name="DOB" value="12/12/2012"/>
    </bean>


</beans>